# Base URL of the Collector.Api backend (HTTPS recommended).
# In dev with the self-signed cert, run `dotnet dev-certs https --trust` once.
API_BASE_URL=https://localhost:5001

# Server-side only: API key the Next.js server uses to fetch public catalog
# data in RSC. Paste the admin key here for dev (get it via
# `cd ../Collector.Api && dotnet user-secrets list`).
API_INTERNAL_KEY=

# Accept self-signed certs when fetching https://localhost:5001 from Node.
# DO NOT set this in production.
NODE_TLS_REJECT_UNAUTHORIZED=0

# Secret for the HMAC that signs the Next.js refresh cookie bundle.
# Generate with: openssl rand -hex 32
SESSION_SECRET=
