{
  "DataDir": "../../data",
  "Api": {
    "AdminApiKey": "",
    "JwtSecret": "",
    "JwtIssuer": "sc-tracker-api",
    "JwtAudience": "sc-tracker-clients",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30,
    "Cors": {
      "AllowedOrigins": [ "http://localhost:3000", "http://localhost:5173" ]
    },
    "Swagger": {
      "Enabled": false
    },
    "RateLimit": {
      "PermitLimit": 100,
      "WindowSeconds": 60
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithThreadId" ],
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*",
  "Urls": "https://localhost:5001;http://localhost:5000"
}
