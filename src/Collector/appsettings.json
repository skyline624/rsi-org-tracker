{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=data/tracker.db"
  },
  "Collector": {
    "CycleInterval": "01:00:00",
    "ErrorDelay": "00:05:00",
    "RateLimitDelaySeconds": 3.0,
    "MaxRetries": 5,
    "BatchSize": 100,
    "MaxConcurrentRequests": 5,
    "DiscoverSortMethods": [ "created_desc" ],
    "MemberCollectionPageSize": 32,
    "OrganizationPageSize": 12,
    "EmptyPagesThreshold": 5
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "data/logs/collector-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}