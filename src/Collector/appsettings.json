{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=data/tracker.db"
  },
  "Collector": {
    "CycleInterval": "01:00:00",
    "ErrorDelay": "00:05:00",
    "RateLimitDelaySeconds": 1.0,
    "MaxRetries": 5,
    "BatchSize": 100,
    "MaxConcurrentRequests": 5,
    "DiscoverSortMethods": [ "created_desc", "created_asc", "size_desc", "size_asc", "active_desc" ],
    "MemberCollectionPageSize": 32,
    "OrganizationPageSize": 12,
    "EmptyPagesThreshold": 5,
    "DiscoveryMaxPages": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}