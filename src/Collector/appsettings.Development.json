{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=data/tracker-dev.db"
  },
  "Collector": {
    "CycleInterval": "00:05:00",
    "ErrorDelay": "00:01:00",
    "RateLimitDelaySeconds": 0.5,
    "MaxRetries": 3,
    "BatchSize": 50,
    "MaxConcurrentRequests": 2,
    "DiscoverSortMethods": [ "created_desc" ],
    "MemberCollectionPageSize": 32,
    "OrganizationPageSize": 12,
    "EmptyPagesThreshold": 3
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}